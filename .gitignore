# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Environment and secrets (use .env.example as a template to commit)
.env
.env.*
!.env.example

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/packages/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android (root-level; android/.gitignore has local.properties, key.properties, etc.)
/android/app/debug
/android/app/profile
/android/app/release
/android/local.properties
/android/.gradle
/android/captures/
/android/**/*.keystore
/android/**/*.jks

# Generated / editor backup
*.bak
*.orig
